name: Deploy Website

on:
  push:
    branches:
      - main  # This triggers the action when there are changes to the main branch

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v2

      - name: Deploy to GitHub Pages
        uses: JamesIves/github-pages-deploy-action@v4
        with:
          branch: gh-pages  # The branch where the website will be published
          folder: public    # The folder that contains your website's HTML, CSS, etc.
